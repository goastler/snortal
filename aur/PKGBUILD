pkgname=portalgun
pkgver=1.0.1
pkgrel=1
pkgdesc='Detect captive portal URLs on a Linux network'
arch=('x86_64' 'aarch64' 'armv7h' 'i686')
url='https://github.com/goastler/captive-portal-finder'
license=('AGPL-3.0-or-later')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/goastler/captive-portal-finder/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "captive-portal-finder-$pkgver"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "captive-portal-finder-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

check() {
    cd "captive-portal-finder-$pkgver"
    cargo test --frozen
}

package() {
    cd "captive-portal-finder-$pkgver"
    install -Dm0755 -t "$pkgdir/usr/bin/" "target/release/$pkgname"
}
